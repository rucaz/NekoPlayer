#!/bin/bash
# NekoPlayer AutoDevQueue - 执行引擎
# 负责: Git操作、自动化工作流、通知

set -e

NEKO_DIR=".neko"
DB_FILE="$NEKO_DIR/queue.db"
TASKS_YAML="$NEKO_DIR/neko-tasks.yml"
SCRIPTS_DIR="$NEKO_DIR/scripts"

# 颜色输出
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# ==================== 工具函数 ====================

log() {
    echo -e "${BLUE}[NEKO]${NC} $1"
}

success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# ==================== 命令实现 ====================

cmd_init() {
    log "初始化 AutoDevQueue..."
    
    mkdir -p "$NEKO_DIR"
    mkdir -p "$NEKO_DIR/scripts"
    
    # 创建Git hooks
    if [ -d ".git" ]; then
        cp "$SCRIPTS_DIR/git-hooks/post-commit" ".git/hooks/" 2>/dev/null || true
        chmod +x ".git/hooks/post-commit" 2>/dev/null || true
        log "Git hooks 已安装"
    fi
    
    # 初始化数据库
    python3 "$SCRIPTS_DIR/scheduler.py" load --yaml "$TASKS_YAML"
    
    success "初始化完成"
}

cmd_status() {
    python3 "$SCRIPTS_DIR/scheduler.py" status
}

cmd_next() {
    python3 "$SCRIPTS_DIR/scheduler.py" next
}

cmd_start() {
    local task_id=$1
    if [ -z "$task_id" ]; then
        # 自动选择最高优先级任务
        task_id=$(python3 -c "
import sys
sys.path.insert(0, '$SCRIPTS_DIR')
from scheduler import TaskScheduler
scheduler = TaskScheduler()
scheduler.load_from_yaml('$TASKS_YAML')
tasks = scheduler.get_next_tasks(1)
if tasks:
    print(tasks[0].id)
")
        if [ -z "$task_id" ]; then
            error "没有可执行的任务"
            return 1
        fi
        log "自动选择任务: $task_id"
    fi
    
    # 获取任务信息
    local module=$(python3 -c "
import yaml
with open('$TASKS_YAML') as f:
    data = yaml.safe_load(f)
    for t in data['tasks']:
        if t['id'] == '$task_id':
            print(t.get('module', 'misc'))
            break
")
    
    # 创建功能分支
    local branch="feature/${module}-${task_id,,}"
    log "创建分支: $branch"
    
    git checkout -b "$branch" 2>/dev/null || git checkout "$branch"
    
    # 更新任务状态
    python3 "$SCRIPTS_DIR/scheduler.py" start --task-id "$task_id"
    
    # 创建任务标记文件
    echo "$task_id" > "$NEKO_DIR/.current_task"
    
    success "任务 $task_id 已启动，请在分支 $branch 上工作"
    
    # 显示任务详情
    echo ""
    echo "📋 任务详情:"
    python3 -c "
import yaml
with open('$TASKS_YAML') as f:
    data = yaml.safe_load(f)
    for t in data['tasks']:
        if t['id'] == '$task_id':
            print(f\"标题: {t['title']}\")
            print(f\"模块: {t['module']}\")
            print(f\"预估: {t.get('estimate', 'N/A')}\")
            print(f\"\")
            print(f\"验收标准:\")
            for c in t.get('criteria', []):
                print(f\"  - {c}\")
            break
"
}

cmd_commit() {
    local message=${1:-"WIP"}
    local task_id=$(cat "$NEKO_DIR/.current_task" 2>/dev/null || echo "")
    
    if [ -n "$task_id" ]; then
        # 获取模块名
        local module=$(python3 -c "
import yaml
with open('$TASKS_YAML') as f:
    data = yaml.safe_load(f)
    for t in data['tasks']:
        if t['id'] == '$task_id':
            print(t.get('module', 'misc'))
            break
")
        # 格式化提交信息
        local formatted_message="${module}(${task_id,,}): ${message}"
        git commit -m "$formatted_message"
    else
        git commit -m "$message"
    fi
}

cmd_complete() {
    local task_id=$(cat "$NEKO_DIR/.current_task" 2>/dev/null || echo "")
    
    if [ -z "$task_id" ]; then
        error "没有正在进行的任务"
        return 1
    fi
    
    # 确保工作区干净
    if [ -n "$(git status --porcelain)" ]; then
        warn "工作区有未提交更改，请先提交"
        git status -s
        return 1
    fi
    
    # 推送分支
    local branch=$(git rev-parse --abbrev-ref HEAD)
    log "推送分支: $branch"
    git push -u origin "$branch"
    
    # 创建PR (需要gh CLI)
    if command -v gh > /dev/null 2>&1; then
        log "创建 Pull Request..."
        
        local title=$(python3 -c "
import yaml
with open('$TASKS_YAML') as f:
    data = yaml.safe_load(f)
    for t in data['tasks']:
        if t['id'] == '$task_id':
            print(f\"{t['id']}: {t['title']}\")
            break
")
        
        local body=$(python3 -c "
import yaml
with open('$TASKS_YAML') as f:
    data = yaml.safe_load(f)
    for t in data['tasks']:
        if t['id'] == '$task_id':
            specs = t.get('content', {}).get('specs', [])
            print('## 任务清单')
            for s in specs:
                print(f\"- [x] {s}\")
            break
")
        
        gh pr create --title "$title" --body "$body" --base develop || warn "PR创建失败，请手动创建"
    else
        warn "未安装 GitHub CLI (gh)，请手动创建 PR"
    fi
    
    # 更新任务状态
    python3 "$SCRIPTS_DIR/scheduler.py" complete --task-id "$task_id"
    
    # 清理当前任务标记
    rm -f "$NEKO_DIR/.current_task"
    
    success "任务 $task_id 已完成，PR已创建"
    
    # 显示下一个推荐任务
    echo ""
    cmd_next
}

cmd_block() {
    local reason=${1:-"未知原因"}
    local task_id=$(cat "$NEKO_DIR/.current_task" 2>/dev/null || echo "")
    
    if [ -n "$task_id" ]; then
        python3 "$SCRIPTS_DIR/scheduler.py" block --task-id "$task_id" --reason "$reason"
    else
        error "没有正在进行的任务"
    fi
}

cmd_report() {
    log "生成开发报告..."
    
    local report_file="$NEKO_DIR/reports/daily-$(date +%Y-%m-%d).md"
    mkdir -p "$(dirname "$report_file")"
    
    cat > "$report_file" << EOF
# NekoPlayer 开发日报 - $(date +%Y-%m-%d)

## 任务队列状态

\`\`\`
$(cmd_status)
\`\`\`

## Git 活动

### 今日提交
\`\`\`
$(git log --since="today" --pretty=format:"%h - %s (%ar)" || echo "无提交")
\`\`\`

### 进行中分支
\`\`\`
$(git branch -vv | grep "^*" || echo "无")
\`\`\`

## 下一步行动

$(cmd_next)

---
*自动生成于 $(date)*
EOF
    
    success "报告已生成: $report_file"
    
    # 发送到飞书 (如果配置了webhook)
    if [ -f "$NEKO_DIR/.feishu_webhook" ]; then
        local webhook=$(cat "$NEIFO_DIR/.feishu_webhook")
        log "发送到飞书..."
        # curl -s -X POST "$webhook" -d "..." > /dev/null || true
    fi
}

cmd_gantt() {
    python3 "$SCRIPTS_DIR/scheduler.py" gantt
    log "甘特图数据已生成，可在 .neko/gantt.json 查看"
    
    # 如果有Node环境，可以生成HTML
    if [ -f "$SCRIPTS_DIR/generate-gantt.js" ] && command -v node > /dev/null 2>&1; then
        node "$SCRIPTS_DIR/generate-gantt.js"
    fi
}

cmd_help() {
    cat << EOF
NekoPlayer AutoDevQueue - 全自动开发任务队列

用法: neko-queue <command> [options]

命令:
  init                  初始化队列系统
  status                查看任务队列状态
  next                  显示接下来可执行的任务
  start [task-id]       开始任务 (不传则自动选择最高优先级)
  commit [message]      提交更改 (自动格式化提交信息)
  complete              完成任务并创建PR
  block [reason]        标记任务阻塞
  report                生成开发报告
  gantt                 导出甘特图数据
  help                  显示帮助

示例:
  neko-queue init
  neko-queue start           # 自动开始最高优先级任务
  neko-queue start LYRICS-001
  neko-queue commit "实现LRC解析器核心"
  neko-queue complete
  neko-queue block "等待API文档"

环境要求:
  - Python 3.8+ (调度引擎)
  - Git (版本控制)
  - gh (GitHub CLI, 可选，用于自动创建PR)

EOF
}

# ==================== 主入口 ====================

case "${1:-help}" in
    init)
        cmd_init
        ;;
    status)
        cmd_status
        ;;
    next)
        cmd_next
        ;;
    start)
        cmd_start "$2"
        ;;
    commit)
        cmd_commit "$2"
        ;;
    complete)
        cmd_complete
        ;;
    block)
        cmd_block "$2"
        ;;
    report)
        cmd_report
        ;;
    gantt)
        cmd_gantt
        ;;
    help|--help|-h)
        cmd_help
        ;;
    *)
        error "未知命令: $1"
        cmd_help
        exit 1
        ;;
esac
